# Lokal (Postgres native): DATABASE_URL dan DIRECT_URL boleh sama.
# Supabase: DATABASE_URL = pooler transaction-mode (port 6543, ?pgbouncer=true),
# DIRECT_URL = koneksi langsung (port 5432) — dipakai Prisma Migrate.
# Ambil dari Supabase dashboard: Project Settings > Database > Connection string.
DATABASE_URL="postgresql://invest:invest@localhost:5432/invest?schema=public"
DIRECT_URL="postgresql://invest:invest@localhost:5432/invest?schema=public"

# FMP — boleh banyak key (dipisah koma) untuk rotasi & lawan rate-limit free tier.
# FMP_API_KEY (tunggal) masih didukung sebagai fallback.
FMP_API_KEYS="key1,key2"

# AI providers — comma-separated key pools (round-robin)
GEMINI_API_KEYS=""
GROQ_API_KEYS=""
OPENROUTER_API_KEYS=""

# Model IDs — verified against official docs 2026-07-04; re-check if providers rename models
GEMINI_MODEL="gemini-3.5-flash"
GROQ_MODEL="openai/gpt-oss-120b"
OPENROUTER_MODEL="google/gemini-3.5-flash"

# Fallback order
AI_PROVIDER_ORDER="gemini,groq,openrouter"
